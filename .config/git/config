[user]
    email = meanderingprogrammer@gmail.com
    name = MeanderingProgrammer
    signingkey = ~/.ssh/id_ed25519.pub

[core]
    autocrlf = input
    commentChar = ";"
    pager = delta

[init]
    defaultBranch = main

[gpg]
    format = ssh

[commit]
    gpgsign = true

[tag]
    gpgsign = true

[delta]
    side-by-side = true

[color]
    grep = always

[diff]
    tool = nvimdiff

[difftool]
    prompt = false

[grep]
    column = true
    lineNumber = true

[include]
    path = config.local
